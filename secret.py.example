# secret.py — 認証情報テンプレート
# このファイルを secret.py にコピーして実際の値を設定してください
# secret.py は .gitignore に含まれています

# Discord Webhook（送信用・既存）
DISCORD_WEBHOOK_URL = 'https://discord.com/api/webhooks/...'

# Discord Bot（コマンド受信用・新規）
# Bot トークンは Discord Developer Portal → Bot → Token で取得
DISCORD_BOT_TOKEN = 'your-bot-token-here'

# コマンドを受け付けるチャンネルの ID（右クリック → IDをコピー）
# Developer Mode を有効にする: User Settings → App Settings → Advanced → Developer Mode
DISCORD_CMD_CHANNEL_ID = 1234567890  # int
